{
  "builds": [
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.json", "use": "@vercel/static" },
    { "src": "*.jpg",  "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/app",   "dest": "/app.html" },
    { "src": "/app/",  "dest": "/app.html" },
    { "src": "/(.*)",  "dest": "/$1" }
  ],
  "headers": [
    {
      "source": "/app.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
